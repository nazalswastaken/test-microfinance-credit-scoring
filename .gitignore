# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
build/
dist/
*.egg-info/

# Jupyter
.ipynb_checkpoints/

# OS
.DS_Store

# IDE
.vscode/
.idea/

# Data — keep raw/processed data out of version control (see data/README.md)
data/raw/*.csv
data/processed/*
!data/processed/.gitkeep

# Trained artifacts and generated reports
models/*
!models/.gitkeep
reports/*
!reports/.gitkeep
